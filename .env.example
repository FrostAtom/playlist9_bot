# Copy this file to .env and fill it in:   cp .env.example .env
# .env is gitignored, so your token and other secrets stay out of version control.
# Anything left blank or commented out uses the default baked into app/config.py.

# ── Required ───────────────────────────────────────────────────────────────
# Bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# ── Optional ───────────────────────────────────────────────────────────────
# Channel id (-100…) where the bot is an admin; enables inline file delivery.
STORAGE_CHAT_ID=

# Password for the bundled PostgreSQL service (DATABASE_URL reuses it).
POSTGRES_PASSWORD=playlist9

# yt-dlp cookies for age-restricted / region-locked content (see README → Cookies).
# COOKIES_FILE=/cookies/cookies.txt

# ── Tuning (uncomment to override; defaults shown) ─────────────────────────
# AUDIO_QUALITY=320          # MP3 kbps (best available source, up to 320)
# MAX_FILE_SIZE_MB=50        # Telegram caps bots at 50
# RATE_PER_MINUTE=10         # max downloads per user per minute
# MAX_RESULTS=30
# RESULTS_PER_PAGE=10
# INLINE_RESULTS=20
# SEARCH_CACHE_SIZE=20
# RESULTS_TTL_SECONDS=300
# DOWNLOAD_PER_USER=3
# DOWNLOAD_TOTAL=8
