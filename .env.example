# ---- Required ----
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ---- Optional (defaults shown) ----
# Max size of a file the bot will send, in MB. Telegram caps bots at 50.
MAX_FILE_SIZE_MB=50

# How many results to fetch per search query.
MAX_RESULTS=30

# How many results to show per page (one track per button).
RESULTS_PER_PAGE=10

# MP3 quality in kbps.
AUDIO_QUALITY=192

# Chat ID used to store freshly downloaded tracks so inline mode can deliver
# them as files (Telegram needs a file_id, which requires uploading somewhere).
# Use a private channel where the bot is an admin; the id looks like -100xxxxxxxxxx.
# Without it, inline mode can only re-send tracks already cached from prior downloads.
STORAGE_CHAT_ID=

